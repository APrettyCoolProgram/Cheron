<Window
    x:Class="CheronStudio.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:CheronStudio"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Cheron Studio"
    Width="1200"
    Height="750"
    MinWidth="800"
    MinHeight="500"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <Window.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#FFF4F6FA" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="White" />
        <SolidColorBrush x:Key="SurfaceMutedBrush" Color="#FFF8FAFC" />
        <SolidColorBrush x:Key="AccentBrush" Color="#FF3B82F6" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FF0F172A" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#FF64748B" />

        <Style TargetType="Button">
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="#FFD9E2EC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="#FFD9E2EC" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style TargetType="Menu">
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>

        <Style TargetType="ToolBarTray">
            <Setter Property="Background" Value="Transparent" />
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True" Background="{StaticResource AppBackgroundBrush}">

        <!-- ═══ Menu Bar ═══ -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="New _Game" Command="{Binding NewGameCommand}" />
                <MenuItem Header="_Open Game..." InputGestureText="Ctrl+O" Click="MenuOpenCartridge_Click" />
                <Separator />
                <MenuItem Header="_Save" InputGestureText="Ctrl+S" Click="MenuSave_Click" />
                <MenuItem Header="Save _As..." InputGestureText="Ctrl+Shift+S" Click="MenuSaveAs_Click" />
                <Separator />
                <MenuItem Header="E_xit" InputGestureText="Alt+F4" Click="MenuExit_Click" />
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="_Undo" InputGestureText="Ctrl+Z" Command="{Binding UndoCommand}" />
                <MenuItem Header="_Redo" InputGestureText="Ctrl+Y" Command="{Binding RedoCommand}" />
                <Separator />
                <MenuItem Header="Cu_t" InputGestureText="Ctrl+X" Command="{Binding CutCommand}" />
                <MenuItem Header="_Copy" InputGestureText="Ctrl+C" Command="{Binding CopyCommand}" />
                <MenuItem Header="_Paste" InputGestureText="Ctrl+V" Command="{Binding PasteCommand}" />
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem x:Name="MenuItemProjectNavigator" 
                          Header="_Project Navigator" 
                          IsCheckable="True"
                          IsChecked="{Binding IsProjectNavigatorVisible, Mode=TwoWay}"
                          Click="MenuViewProjectNavigator_Click" />
            </MenuItem>
        </Menu>

        <!-- ═══ Toolbar ═══ -->
        <ToolBarTray DockPanel.Dock="Top">
            <ToolBar>
                <Button ToolTip="New Game (Ctrl+N)"  Click="MenuNewGame_Click">New</Button>
                <Button ToolTip="Open Cartridge (Ctrl+O)" Click="MenuOpenCartridge_Click">Open</Button>
                <Button ToolTip="Save (Ctrl+S)"      Click="MenuSave_Click">Save</Button>
                <Separator />
                <Button ToolTip="Run Game"           Click="MenuRun_Click">Run</Button>
                <Button ToolTip="Build Game"         Click="MenuBuild_Click">Build</Button>
                <Separator />
                <Button ToolTip="Preferences"        Click="MenuPreferences_Click">Settings</Button>
            </ToolBar>
        </ToolBarTray>

        <!-- ═══ Status Bar ═══ -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem DockPanel.Dock="Right">
                <TextBlock x:Name="ProjectStatusText" Text="No project open" />
            </StatusBarItem>
            <Separator DockPanel.Dock="Right" />
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Ready" />
            </StatusBarItem>
        </StatusBar>

        <!-- ═══ Main Content Area ═══ -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="NavigatorColumn" Width="220" MinWidth="150" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="*" MinWidth="400" />
            </Grid.ColumnDefinitions>

            <!-- Project Navigator (Left Panel) -->
            <DockPanel x:Name="NavigatorPanel" Grid.Column="0">
                <Border DockPanel.Dock="Top"
                        BorderThickness="0,0,0,1"
                        BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                        Padding="8,5">
                    <TextBlock Text="PROJECT NAVIGATOR"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
                </Border>
                <TreeView x:Name="ProjectNavigator" BorderThickness="0">
                    <TreeViewItem Header="(No project open)" IsEnabled="False" />
                </TreeView>
            </DockPanel>

            <!-- Navigator / Workspace Splitter -->
            <GridSplitter x:Name="NavigatorSplitter"
                          Grid.Column="1"
                          Width="4"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch" />

            <!-- Workspace + Output (Right Area) -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" MinHeight="200" />
                    <RowDefinition x:Name="OutputSplitterRow" Height="4" />
                    <RowDefinition x:Name="OutputRow" Height="150" MinHeight="80" />
                </Grid.RowDefinitions>

                <!-- Workspace Tabs -->
                <TabControl x:Name="WorkspaceTabControl" Grid.Row="0">
                    <TabItem Header="Welcome">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="36,28">


                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>

                <!-- Workspace / Output Splitter -->
                <GridSplitter Grid.Row="1"
                              Height="4"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch" />

                <!-- Output Panel -->
                <DockPanel x:Name="OutputPanel" Grid.Row="2">
                    <Border DockPanel.Dock="Top"
                            BorderThickness="0,1,0,0"
                            BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                            Padding="8,4">
                        <TextBlock Text="OUTPUT"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
                    </Border>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <TextBox x:Name="OutputTextBox"
                                 IsReadOnly="True"
                                 BorderThickness="0"
                                 FontFamily="Consolas"
                                 FontSize="12"
                                 Background="Transparent"
                                 Text="Cheron Studio ready." />
                    </ScrollViewer>
                </DockPanel>

            </Grid>
        </Grid>

    </DockPanel>

</Window>
