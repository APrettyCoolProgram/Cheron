<Window
    x:Class="CheronStudio.TekstEngine.TekstEngineWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:CheronStudio.TekstEngine"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Cheron Studio: Tekst Engine"
    Width="800"
    Height="600"
    mc:Ignorable="d">
    <Grid>
        <!--<Border
            x:Name="brdCartridgeControls"
            Margin="10,10,10,364"
            Padding="10"
            BorderBrush="Black"
            BorderThickness="1"
            CornerRadius="5">-->
        <WrapPanel
                x:Name="TopMenu"
                Margin="10">
            <Label
                    x:Name="lblTekstEngine"
                    Width="149"
                    Height="38"
                    Padding="5,5,0,0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    BorderBrush="Black"
                    BorderThickness="1"
                    Content="Tekst Engine"
                    FontFamily="Bahnschrift"
                    FontSize="24">
                <Label.Resources>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="CornerRadius" Value="5" />
                    </Style>
                </Label.Resources>
            </Label>
            <Label
                    x:Name="lblCartridgeControls"
                    Width="70"
                    Padding=" 0,10"
                    Margin="350,0,0,0"
                    Height="38"
                    FontFamily="Bahnschrift"
                    FontSize="16"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Content="Cartridge" />
            <Button
                    x:Name="btnLoadCartridge"
                    Width="60"
                    Height="25"
                    Margin="10,0,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Content="Load">
                <Button.Resources>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="CornerRadius" Value="5" />
                    </Style>
                </Button.Resources>
            </Button>
            <Button
                    x:Name="btnNewCartridge"
                    Width="60"
                    Height="25"
                    Margin="10,0,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Content="New">
                <Button.Resources>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="CornerRadius" Value="5" />
                    </Style>
                </Button.Resources>
            </Button>
            <Button
                    x:Name="btnPlayCartridge"
                    Width="60"
                    Height="25"
                    Margin="10,0,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Content="Play">
                <Button.Resources>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="CornerRadius" Value="5" />
                    </Style>
                </Button.Resources>
            </Button>
        </WrapPanel>
        <!--</Border>-->

        <TabControl x:Name="tabctrlControl" Margin="10,60,10,10">
            <TabItem x:Name="tabitemGameDetail" Header="GameDetail">
                <Grid Background="#FFE5E5E5" />
            </TabItem>
            <TabItem x:Name="tabitemOpeningCredits" Header="Opening Credits">
                <Grid Background="#FFE5E5E5" />
            </TabItem>
            <TabItem x:Name="tabitemWinRule" Header="Win Rule">
                <Grid Background="#FFE5E5E5" />
            </TabItem>
            <TabItem x:Name="tabitemRooms" Header="Rooms">
                <Grid Background="#FFE5E5E5" />
            </TabItem>
            <TabItem x:Name="tabitemItems" Header="Items">
                <Grid Background="#FFE5E5E5" />
            </TabItem>
            <TabItem x:Name="tabitemExit" Header="Exit">
                <Grid Background="#FFE5E5E5" />
            </TabItem>
            <TabItem x:Name="tabitemClosingCredits" Header="Closing Credits">
                <Grid Background="#FFE5E5E5" />
            </TabItem>
        </TabControl>


    </Grid>
</Window>
