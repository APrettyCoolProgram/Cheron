<Window
    x:Class="CheronStudio.TekstEngine.TekstEngineWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Cheron Studio: Tekst Engine"
    Width="1000"
    Height="720"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <WrapPanel Margin="10">
            <Label
                x:Name="lblTekstEngine"
                Width="149"
                Height="38"
                Padding="5,5,0,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                BorderBrush="Black"
                BorderThickness="1"
                Content="Tekst Engine"
                FontFamily="Bahnschrift"
                FontSize="24">
                <Label.Resources>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="CornerRadius" Value="5" />
                    </Style>
                </Label.Resources>
            </Label>

            <Label
                x:Name="lblCartridgeControls"
                Width="70"
                Height="38"
                Margin="350,0,0,0"
                Padding="0,10"
                FontFamily="Bahnschrift"
                FontSize="16"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Content="Cartridge" />

            <Button
                x:Name="btnLoadCartridge"
                Width="60"
                Height="25"
                Margin="10,0,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Click="btnLoadCartridge_Click"
                Content="Load">
                <Button.Resources>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="CornerRadius" Value="5" />
                    </Style>
                </Button.Resources>
            </Button>

            <Button
                x:Name="btnNewCartridge"
                Width="60"
                Height="25"
                Margin="10,0,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Click="btnNewCartridge_Click"
                Content="New">
                <Button.Resources>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="CornerRadius" Value="5" />
                    </Style>
                </Button.Resources>
            </Button>

            <Button
                x:Name="btnSaveCartridge"
                Width="60"
                Height="25"
                Margin="10,0,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Click="btnSaveCartridge_Click"
                Content="Save">
                <Button.Resources>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="CornerRadius" Value="5" />
                    </Style>
                </Button.Resources>
            </Button>

            <Button
                x:Name="btnPlayCartridge"
                Width="60"
                Height="25"
                Margin="10,0,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Click="btnPlayCartridge_Click"
                Content="Play">
                <Button.Resources>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="CornerRadius" Value="5" />
                    </Style>
                </Button.Resources>
            </Button>
        </WrapPanel>

        <TabControl Grid.Row="1" x:Name="tabctrlControl" Margin="10">
            <TabItem x:Name="tabitemGameDetail" Header="Game Detail">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <TextBlock Text="Game Title" />
                        <TextBox x:Name="txtGameTitle" Margin="0,0,0,8" />

                        <TextBlock Text="Game Author" />
                        <TextBox x:Name="txtGameAuthor" Margin="0,0,0,8" />

                        <TextBlock Text="Game Version" />
                        <TextBox x:Name="txtGameVersion" Margin="0,0,0,8" />

                        <TextBlock Text="Game Description" />
                        <TextBox x:Name="txtGameDescription" Margin="0,0,0,8" AcceptsReturn="True" Height="80" TextWrapping="Wrap" />

                        <TextBlock Text="Game Engine" />
                        <TextBox x:Name="txtGameEngine" Margin="0,0,0,8" />

                        <TextBlock Text="Game Type" />
                        <TextBox x:Name="txtGameType" Margin="0,0,0,8" />

                        <TextBlock Text="Game Type Variation" />
                        <TextBox x:Name="txtGameTypeVariation" Margin="0,0,0,8" />

                        <TextBlock Text="Game Color Scheme" />
                        <TextBox x:Name="txtGameColorScheme" Margin="0,0,0,8" />

                        <TextBlock Text="Game Genre" />
                        <TextBox x:Name="txtGameGenre" Margin="0,0,0,8" />

                        <TextBlock Text="Game Difficulty" />
                        <TextBox x:Name="txtGameDifficulty" Margin="0,0,0,8" />

                        <TextBlock Text="Text Game Type" />
                        <TextBox x:Name="txtTextGameType" Margin="0,0,0,8" />

                        <TextBlock Text="Starting Room Id" />
                        <TextBox x:Name="txtStartingRoomId" Margin="0,0,0,8" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem x:Name="tabitemOpeningCredits" Header="Opening Credits">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <TextBlock Text="Banner" />
                        <TextBox x:Name="txtBanner" Margin="0,0,0,8" AcceptsReturn="True" Height="140" TextWrapping="Wrap" />

                        <TextBlock Text="Intro" />
                        <TextBox x:Name="txtIntro" Margin="0,0,0,8" AcceptsReturn="True" Height="100" TextWrapping="Wrap" />

                        <TextBlock Text="Help Prompt" />
                        <TextBox x:Name="txtHelpPrompt" Margin="0,0,0,8" AcceptsReturn="True" Height="80" TextWrapping="Wrap" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem x:Name="tabitemWinRule" Header="Win Rule">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <TextBlock Text="Required Item Id" />
                        <TextBox x:Name="txtRequiredItemId" Margin="0,0,0,8" />

                        <TextBlock Text="Required Room Id" />
                        <TextBox x:Name="txtRequiredRoomId" Margin="0,0,0,8" />

                        <TextBlock Text="Victory Text" />
                        <TextBox x:Name="txtVictoryText" Margin="0,0,0,8" AcceptsReturn="True" Height="140" TextWrapping="Wrap" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem x:Name="tabitemRooms" Header="Rooms">
                <DockPanel Margin="10">
                    <TextBlock
                        DockPanel.Dock="Top"
                        Margin="0,0,0,8"
                        Text="Edit the rooms array as JSON." />
                    <TextBox
                        x:Name="txtRooms"
                        AcceptsReturn="True"
                        HorizontalScrollBarVisibility="Auto"
                        VerticalScrollBarVisibility="Auto"
                        TextWrapping="NoWrap" />
                </DockPanel>
            </TabItem>

            <TabItem x:Name="tabitemItems" Header="Items">
                <Grid Background="#FFE5E5E5">
                    <TextBlock
                        Margin="10"
                        Text="Item editing can be expanded here later. Items are currently edited inside the Rooms JSON." />
                </Grid>
            </TabItem>

            <TabItem x:Name="tabitemExit" Header="Exit">
                <Grid Background="#FFE5E5E5">
                    <TextBlock
                        Margin="10"
                        Text="Exit editing can be expanded here later. Exits are currently edited inside the Rooms JSON." />
                </Grid>
            </TabItem>

            <TabItem x:Name="tabitemClosingCredits" Header="Closing Credits">
                <Grid Background="#FFE5E5E5">
                    <TextBlock
                        Margin="10"
                        Text="No closing-credits field exists in the current cartridge format." />
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
