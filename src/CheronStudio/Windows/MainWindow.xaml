<Window
    x:Class="CheronStudio.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:CheronStudio"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Cheron Studio"
    Width="1200"
    Height="750"
    MinWidth="800"
    MinHeight="500"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <DockPanel LastChildFill="True">

        <!-- ═══ Menu Bar ═══ -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_New Game"       InputGestureText="Ctrl+N"       Click="MenuNewGame_Click" />
                <MenuItem Header="_Open Game..."   InputGestureText="Ctrl+O"       Click="MenuOpenGame_Click" />
                <Separator />
                <MenuItem Header="_Save"           InputGestureText="Ctrl+S"       Click="MenuSave_Click" />
                <MenuItem Header="Save _As..."     InputGestureText="Ctrl+Shift+S" Click="MenuSaveAs_Click" />
                <Separator />
                <MenuItem Header="E_xit"           InputGestureText="Alt+F4"       Click="MenuExit_Click" />
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="_Undo"   InputGestureText="Ctrl+Z" />
                <MenuItem Header="_Redo"   InputGestureText="Ctrl+Y" />
                <Separator />
                <MenuItem Header="Cu_t"   InputGestureText="Ctrl+X" />
                <MenuItem Header="_Copy"  InputGestureText="Ctrl+C" />
                <MenuItem Header="_Paste" InputGestureText="Ctrl+V" />
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem x:Name="MenuItemProjectNavigator"
                          Header="_Project Navigator"
                          IsCheckable="True"
                          IsChecked="True"
                          Click="MenuViewProjectNavigator_Click" />
                <MenuItem x:Name="MenuItemOutput"
                          Header="_Output"
                          IsCheckable="True"
                          IsChecked="True"
                          Click="MenuViewOutput_Click" />
                <Separator />
                <MenuItem Header="_Reset Layout" Click="MenuResetLayout_Click" />
            </MenuItem>
            <MenuItem Header="_Game">
                <MenuItem Header="_Run"             Click="MenuRun_Click" />
                <MenuItem Header="_Build"           Click="MenuBuild_Click" />
                <Separator />
                <MenuItem Header="_Game Properties" Click="MenuGameProperties_Click" />
            </MenuItem>
            <MenuItem Header="_Tools">
                <MenuItem Header="_Preferences"     Click="MenuPreferences_Click" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_Documentation"      Click="MenuDocumentation_Click" />
                <Separator />
                <MenuItem Header="_About Cheron Studio" Click="MenuAbout_Click" />
            </MenuItem>
        </Menu>

        <!-- ═══ Toolbar ═══ -->
        <ToolBarTray DockPanel.Dock="Top">
            <ToolBar>
                <Button ToolTip="New Game (Ctrl+N)"  Click="MenuNewGame_Click">New</Button>
                <Button ToolTip="Open Game (Ctrl+O)" Click="MenuOpenGame_Click">Open</Button>
                <Button ToolTip="Save (Ctrl+S)"      Click="MenuSave_Click">Save</Button>
                <Separator />
                <Button ToolTip="Run Game"           Click="MenuRun_Click">Run</Button>
                <Button ToolTip="Build Game"         Click="MenuBuild_Click">Build</Button>
                <Separator />
                <Button ToolTip="Preferences"        Click="MenuPreferences_Click">Settings</Button>
            </ToolBar>
        </ToolBarTray>

        <!-- ═══ Status Bar ═══ -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem DockPanel.Dock="Right">
                <TextBlock x:Name="ProjectStatusText" Text="No project open" />
            </StatusBarItem>
            <Separator DockPanel.Dock="Right" />
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Ready" />
            </StatusBarItem>
        </StatusBar>

        <!-- ═══ Main Content Area ═══ -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="NavigatorColumn" Width="220" MinWidth="150" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="*" MinWidth="400" />
            </Grid.ColumnDefinitions>

            <!-- Project Navigator (Left Panel) -->
            <DockPanel x:Name="NavigatorPanel" Grid.Column="0">
                <Border DockPanel.Dock="Top"
                        BorderThickness="0,0,0,1"
                        BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                        Padding="8,5">
                    <TextBlock Text="PROJECT NAVIGATOR"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
                </Border>
                <TreeView x:Name="ProjectNavigator" BorderThickness="0">
                    <TreeViewItem Header="(No project open)" IsEnabled="False" />
                </TreeView>
            </DockPanel>

            <!-- Navigator / Workspace Splitter -->
            <GridSplitter x:Name="NavigatorSplitter"
                          Grid.Column="1"
                          Width="4"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch" />

            <!-- Workspace + Output (Right Area) -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" MinHeight="200" />
                    <RowDefinition x:Name="OutputSplitterRow" Height="4" />
                    <RowDefinition x:Name="OutputRow" Height="150" MinHeight="80" />
                </Grid.RowDefinitions>

                <!-- Workspace Tabs -->
                <TabControl x:Name="WorkspaceTabControl" Grid.Row="0">
                    <TabItem Header="Welcome">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="36,28">

                                <TextBlock Text="Cheron Studio"
                                           FontSize="28"
                                           FontWeight="Light"
                                           Margin="0,0,0,4" />
                                <TextBlock Text="Game development for the Cheron ecosystem"
                                           FontSize="13"
                                           Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                           Margin="0,0,0,32" />

                                <TextBlock Text="Start"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,10" />
                                <Button Width="160"
                                        HorizontalAlignment="Left"
                                        Padding="10,6"
                                        Margin="0,0,0,6"
                                        Click="MenuNewGame_Click">New Game</Button>
                                <Button Width="160"
                                        HorizontalAlignment="Left"
                                        Padding="10,6"
                                        Margin="0,0,0,28"
                                        Click="MenuOpenGame_Click">Open Game...</Button>

                                <TextBlock Text="Recent Projects"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,10" />
                                <TextBlock Text="No recent projects."
                                           Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                           FontStyle="Italic" />

                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>

                <!-- Workspace / Output Splitter -->
                <GridSplitter Grid.Row="1"
                              Height="4"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch" />

                <!-- Output Panel -->
                <DockPanel x:Name="OutputPanel" Grid.Row="2">
                    <Border DockPanel.Dock="Top"
                            BorderThickness="0,1,0,0"
                            BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                            Padding="8,4">
                        <TextBlock Text="OUTPUT"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
                    </Border>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <TextBox x:Name="OutputTextBox"
                                 IsReadOnly="True"
                                 BorderThickness="0"
                                 FontFamily="Consolas"
                                 FontSize="12"
                                 Background="Transparent"
                                 Text="Cheron Studio ready." />
                    </ScrollViewer>
                </DockPanel>

            </Grid>
        </Grid>

    </DockPanel>

</Window>
