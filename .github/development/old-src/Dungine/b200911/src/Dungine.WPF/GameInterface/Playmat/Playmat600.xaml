-->

<!--
    NOTE: This documentation will eventually be moved outside of this file, but will remain here during development.

    About Dungine Playmats
    ======================
    Playmats are the foundation of games created using Dungine. Each playmat is designed for a specific game, and can be
    used to create other games of the same type.

    About Playmat600
    ================
    Playmat600 was originally developed for Dungeon: Moonshot (https://github.com/calistadalanegames/dungeon.moonshot),
    an entry in the itch.io Game Off 2020. Dungeon: Moonshot is an experimental rogue-like role-playing dungeon crawler
    that takes inspiration from games like the Might & Magic series, NetHack, and Hunt the Wumpus.

    Playmat600 layout
    =================

    Playmat600 is split into 6 sections:

    **********************************************************
    *     Not used     *    Room view     *     Not used     *
    **********************************************************
    *     Not used     *     Not used     *   App controls   *
    **********************************************************
    *     Not used     *    Text view     *     Not used     *
    **********************************************************

    Room view   : shows the room view, and any actors
    App controls: save, load, quit buttons
    Text view   : text descriptions and user interaction
-->

<Window x:Class="Dungine.WPF.Playmat.Playmat600"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:Dungine.WPF.Playmat"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        x:Name="playmat600"
        Title="Playmat #600 - Dungeon: Moonshot "
        Width="1400"
        Height="1000"
        Background="#FF9DD1B8"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        mc:Ignorable="d">

    <Grid x:Name="mainGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="mainGridColumnLeft"
                              Width="350" />
            <ColumnDefinition x:Name="mainGridColumnLeftCenter"
                              Width="350" />
            <ColumnDefinition x:Name="mainGridColumnRightCenter"
                              Width="350" />
            <ColumnDefinition x:Name="mainGridColumnRight"
                              Width="350" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition x:Name="mainGridRowTop"
                           Height="450" />
            <RowDefinition x:Name="mainGridRowMiddle"
                           Height="100" />
            <RowDefinition x:Name="mainGridRowBottom"
                           Height="450" />
        </Grid.RowDefinitions>

        <!--
            The upper left component is currently unused.
        -->
        <Border x:Name="brdUpperLeftSection"
                Margin="10,10,5,5"
                Background="White"
                BorderBrush="Black"
                BorderThickness="1"
                CornerRadius="5" />

        <!--
            Room view component shows the room view and actors.
        -->
        <Border x:Name="brdRoomView"
                Grid.Column="1"
                Grid.ColumnSpan="2"
                Margin="5,10,5,5"
                BorderBrush="Black"
                BorderThickness="1"
                CornerRadius="5">
            <Border.Background>
                <ImageBrush ImageSource="/application-data/asset/image/embedded/dungeon-moonshot-room-view-concept01-986x436.png" />
            </Border.Background>
            <DockPanel x:Name="dpnEnemyDisplay"
                       Width="600"
                       Height="300"
                       Margin="0"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Bottom"
                       LastChildFill="False">
                <Image x:Name="imgEnemyLeft"
                       Width="200"
                       Source="/application-data/asset/image/embedded/monster-concept01.png" />
                <Image x:Name="imgEnemyCenter"
                       Width="200"
                       Source="/application-data/asset/image/embedded/monster-concept01.png" />
                <Image x:Name="imgEnemyRight"
                       Width="200"
                       Source="/application-data/asset/image/embedded/monster-concept01.png" />
            </DockPanel>
        </Border>

        <!--
            The upper right component is currently unused.
        -->
        <Border x:Name="brdUpperightSection"
                Grid.Column="3"
                Margin="5, 10, 10 ,5"
                Background="White"
                BorderBrush="Black"
                BorderThickness="1"
                CornerRadius="5" />

        <!--
            The middle left component is currently unused.
        -->
        <Border x:Name="brdMiddleLeftSection"
                Grid.Row="1"
                Margin="10,5,5,5"
                BorderBrush="Black"
                BorderThickness="0"
                CornerRadius="5" />

        <!--
            The middle center component is currently unused.
        -->
        <Border x:Name="brdMiddleCenterBorderSection"
                Grid.Row="1"
                Grid.Column="1"
                Margin="5,5,5,5"
                BorderBrush="Black"
                BorderThickness="1"
                CornerRadius="5" />

        <!--
            App control component contains application controls.
        -->
        <Border x:Name="brdApplicationControls"
                Grid.Row="1"
                Grid.Column="3"
                Margin="5,5,10,5"
                BorderBrush="Black"
                BorderThickness="0"
                CornerRadius="5">
            <WrapPanel x:Name="wpnApplicationControls"
                       HorizontalAlignment="Center">
                <Button x:Name="btnTemporary"
                        Width="65"
                        Height="65"
                        Margin="8,12,8,8"
                        Content="Temp" />
                <Button x:Name="btnGameSave"
                        Width="65"
                        Height="65"
                        Margin="8,12,8,8"
                        Content="Save" />
                <Button x:Name="btnGameLoad"
                        Width="65"
                        Height="65"
                        Margin="8,12,8,8"
                        Content="Load" />
                <Button x:Name="btnGameQuit"
                        Width="65"
                        Height="65"
                        Margin="8,12,8,8"
                        Click="btnGameQuit_Click"
                        Content="Quit" />
            </WrapPanel>
        </Border>

        <!--
            Bottom left component is currently unused.
        -->
        <Border x:Name="brdBottomLeftSection"
                Grid.Row="2"
                Margin="10,5,5,10"
                Background="White"
                BorderBrush="Black"
                BorderThickness="1"
                CornerRadius="5" />
        <!--
            Text view component displays text descriptions and user interaction
        -->
        <Border x:Name="brdTextView"
                Grid.Row="2"
                Grid.Column="1"
                Margin="5,5,5,10"
                Background="White"
                BorderBrush="Black"
                BorderThickness="1"
                CornerRadius="5" />

        <!--
            Bottom right component is currently unused.
        -->
        <Border x:Name="brdBottomRightSection"
                Grid.Row="2"
                Grid.Column="2"
                Margin="5,5,10,10"
                Background="White"
                BorderBrush="Black"
                BorderThickness="1"
                CornerRadius="5" />
    </Grid>
</Window>

