<Window
    x:Class="Cheron.PaletteSwapper.PaletteSwapperWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Cheron.PaletteSwapper"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Cheron &gt; Palette Swapper"
    Width="1200"
    Height="700"
    ResizeMode="NoResize"
    mc:Ignorable="d">

    <!--
        There are three columns in this window:
        LEFT: The original image
        CENTER: Various controls
        RIGHT: The modified image
    -->

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="512" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="512" />
        </Grid.ColumnDefinitions>
        <!--
            LEFT COLUMN - ORIGINAL IMAGE - CONTAINER BORDER
            Contains everything related to the original image.
        -->
        <Border
            x:Name="brdrLeftColumn"
            Grid.Column="0"
            Margin="10"
            BorderBrush="Black"
            BorderThickness="2"
            CornerRadius="10">
            <!--
                ORIGINAL IMAGE - CONTAINER PANEL
                Contains everything related to the original image.
            -->
            <StackPanel x:Name="spnlOriginalImageContainer" Orientation="Vertical">
                <!--
                    ORIGINAL IMAGE - TOP MENU PANEL
                    Contains all of the controls at the top of the original image section.
                -->
                <StackPanel
                    x:Name="spnlOriginalImageTopMenuRight"
                    Margin="0,0,0,5"
                    Orientation="Horizontal">
                    <!--
                        ORIGINAL IMAGE - TOP MENU - LEFT COLUMN
                        Contains the "ORIGINAL" label and bling border.
                    -->
                    <StackPanel
                        x:Name="spnlOriginalImageTopMenuLeft"
                        HorizontalAlignment="Left"
                        Orientation="Vertical">
                        <!--  ORIGINAL IMAGE LABEL  -->
                        <Label
                            x:Name="lblOriginalImage"
                            Width="100"
                            Margin="20,0,0,0"
                            HorizontalAlignment="left"
                            Content="ORIGINAL"
                            FontFamily="Barlow"
                            FontSize="16"
                            FontWeight="Bold" />
                        <!--  ORIGINAL IMAGE BLING  -->
                        <Border
                            x:Name="brdrOriginalImageBling"
                            Width="350"
                            Margin="12,0,0,0"
                            BorderBrush="Goldenrod"
                            BorderThickness="2" />
                    </StackPanel>
                    <!--
                        ORIGINAL IMAGE - TOP MENU PANEL - RIGHT COLUMN
                        Contains the load button.
                    -->
                    <Button
                        x:Name="btnLoadOriginalImage"
                        Width="50"
                        Margin="50,5,0,0"
                        Background="White"
                        Click="btnLoadOriginalImage_Click"
                        Content="LOAD"
                        FontFamily="Urbanist"
                        FontSize="12"
                        FontWeight="SemiBold">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="3" />
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
                <!--
                    ORIGINAL IMAGE
                    Contains the original image.
                -->
                <Border
                    x:Name="brdrOriginalImage"
                    Grid.Column="0"
                    Margin="5,0,5,0"
                    Background="WhiteSmoke"
                    BorderBrush="Black"
                    BorderThickness="2"
                    ClipToBounds="True"
                    CornerRadius="0">
                    <Image
                        x:Name="imgOriginal"
                        Height="512"
                        Margin="0,10,0,0" />
                </Border>
                <!--
                    ORIGINAL IMAGE - BOTTOM MENU PANEL
                    Contains all of the controls at the bottom of the original image section.
                -->
                <StackPanel
                    x:Name="spnlOriginalImageBottomMenu"
                    Height="40"
                    Orientation="Horizontal">
                    <!--  ORIGINAL IMAGE ZOOM LABEL  -->
                    <Label
                        x:Name="lblOriginalZoom"
                        Width="55"
                        Margin="55,0,0,0"
                        VerticalAlignment="Center"
                        Content="ZOOM"
                        FontFamily="Barlow"
                        FontSize="16"
                        FontWeight="Bold" />
                    <!--  ORIGINAL IMAGE ZOOM SLIDER  -->
                    <Slider
                        x:Name="sldrOriginalZoom"
                        Width="280"
                        Margin="5,12,0,10"
                        Maximum="3.0"
                        Minimum="1.0"
                        ValueChanged="sldrOriginalZoom_ValueChanged"
                        Value="1.0" />
                    <!--  ORIGINAL IMAGE ZOOM PERCENTAGE LABEL  -->
                    <Label
                        x:Name="lblOriginalZoomPercent"
                        Height="29"
                        Margin="0,8"
                        Content="100%"
                        FontFamily="Urbanist"
                        FontSize="14" />
                    <!--  ORIGINAL IMAGE ZOOM RESET BUTTON  -->
                    <Button
                        x:Name="btnResetOriginalZoom"
                        Width="32"
                        Height="32"
                        Margin="0,0,10,0"
                        Background="White"
                        Click="btnResetOriginalZoom_Click"
                        Content="R"
                        FontFamily="Urbanist"
                        FontSize="14"
                        FontWeight="SemiBold">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="3" />
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>
        <!--
            MIDDLE COLUMN - CONTROLS PANEL
            Contains everything related to the original image.
        -->
        <StackPanel
            x:Name="splnMiddleColumn"
            Grid.Column="1"
            Orientation="Vertical">
            <!--  FROM COLOR LABEL  -->
            <Label
                x:Name="lblFromColor"
                Margin="0,100,0,0"
                HorizontalAlignment="Center"
                Content="FROM"
                FontFamily="Barlow"
                FontSize="18"
                FontWeight="Bold" />
            <!--  FROM COLOR BUTTON  -->
            <Button
                x:Name="btnFromColor"
                Width="128"
                Height="128"
                Margin="0,0"
                Background="WhiteSmoke"
                Content="" Click="btnFromColor_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="10" />
                    </Style>
                </Button.Resources>
            </Button>
            <!--  TO COLOR LABEL  -->
            <Label
                x:Name="lblToColor"
                Margin="0,10,0,0"
                HorizontalAlignment="Center"
                Content="TO"
                FontFamily="Barlow"
                FontSize="18"
                FontWeight="Bold" />
            <!--  TO COLOR BUTTON  -->
            <Button
                x:Name="btnToColor"
                Width="128"
                Height="128"
                Margin="0,0"
                Background="WhiteSmoke"
                Content="" Click="btnToColor_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="10" />
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
        <!--
            RIGHT COLUMN - MODIFIED IMAGE - CONTAINER BORDER
            Contains everything related to the modified image.
        -->
        <Border
            x:Name="brdrRightColumn"
            Grid.Column="2"
            Margin="10"
            BorderBrush="Black"
            BorderThickness="2"
            CornerRadius="10">
            <!--    -->
            <StackPanel x:Name="spnlModifiedImageContainer" Orientation="Vertical">
                <!--    -->
                <StackPanel
                    x:Name="spnlModifiedImageTopMenu"
                    Margin="0,0,0,5"
                    Orientation="Horizontal">
                    <!--    -->
                    <StackPanel
                        x:Name="spnlModifiedImageTopMenuRight"
                        Width="489"
                        Orientation="Horizontal">
                        <!--    -->
                        <StackPanel
                            x:Name="spnlModifiedImageTopMenuLeft"
                            HorizontalAlignment="Left"
                            Orientation="Vertical">
                            <!--    -->
                            <Label
                                x:Name="lblModifiedImage"
                                Width="100"
                                Margin="20,0,0,0"
                                HorizontalAlignment="left"
                                Content="MODIFIED"
                                FontFamily="Barlow"
                                FontSize="16"
                                FontWeight="Bold" />
                            <!--    -->
                            <Border
                                x:Name="brdrModifiedImageBling"
                                Width="350"
                                Margin="12,0,0,0"
                                BorderBrush="IndianRed"
                                BorderThickness="2" />
                        </StackPanel>
                        <!--    -->
                        <Button
                            x:Name="btnSaveModifiedImage"
                            Width="50"
                            Height="32"
                            Margin="50,0,0,0"
                            Background="White"
                            Content="SAVE"
                            FontFamily="Urbanist"
                            FontSize="12"
                            FontWeight="SemiBold">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="3" />
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </StackPanel>
                <!--    -->
                <Border
                    x:Name="brdrModifiedImage"
                    Grid.Column="0"
                    Margin="5,0,5,0"
                    Background="WhiteSmoke"
                    BorderBrush="Black"
                    BorderThickness="1"
                    CornerRadius="10">
                    <!--    -->
                    <Image
                        x:Name="imgModified"
                        Height="512"
                        Margin="0,10,0,0" />
                </Border>
                <!--    -->
                <StackPanel x:Name="spnlModifiedImageBottomMenu" Orientation="Vertical">
                    <!--    -->
                    <StackPanel
                        x:Name="spnlModifiedImageBottomMenuZoom"
                        Height="40"
                        Orientation="Horizontal">
                        <!--    -->
                        <Label
                            x:Name="lblModifiedZoom"
                            Width="55"
                            Margin="55,0,0,0"
                            VerticalAlignment="Center"
                            HorizontalContentAlignment="Right"
                            Content="ZOOM"
                            FontFamily="Barlow"
                            FontSize="16"
                            FontWeight="Bold" />
                        <!--    -->
                        <Slider
                            x:Name="sldrModifiedZoom"
                            Width="280"
                            Margin="5,12,0,10" />
                        <!--  MODIFIED IMAGE ZOOM PERCENTAGE LABEL  -->
                        <Label
                            x:Name="lblModifiedZoomPercent"
                            Height="29"
                            Margin="0,8"
                            Content="100%"
                            FontFamily="Urbanist"
                            FontSize="14" />
                        <!--    -->
                        <Button
                            x:Name="btnResetModifiedZoom"
                            Width="32"
                            Height="32"
                            Margin="0,0,10,0"
                            Background="White"
                            Content="R"
                            FontFamily="Urbanist"
                            FontSize="14"
                            FontWeight="SemiBold">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="3" />
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                    <!--    -->
                    <StackPanel
                        x:Name="spnlModifiedImageBottomMenuTolerance"
                        Height="40"
                        Orientation="Horizontal">
                        <!--    -->
                        <Label
                            x:Name="lblModifiedTolerance"
                            Width="100"
                            Margin="10,0,0,0"
                            VerticalAlignment="Center"
                            Content="TOLERANCE"
                            FontFamily="Barlow"
                            FontSize="16"
                            FontWeight="Bold" />
                        <!--    -->
                        <Slider
                            x:Name="sldrModifiedTolerance"
                            Width="280"
                            Margin="5,12,0,10" />
                        <!--  MODIFIED IMAGE TOLERANCE PERCENTAGE LABEL  -->
                        <Label
                            x:Name="lblModifiedTolerancePercent"
                            Height="29"
                            Margin="0,8"
                            Content="100%"
                            FontFamily="Urbanist"
                            FontSize="14" />
                        <!--    -->
                        <Button
                            x:Name="btnResetModifiedTolerance"
                            Width="32"
                            Height="32"
                            Margin="0,0,10,0"
                            Background="White"
                            Content="R"
                            FontFamily="Urbanist"
                            FontSize="14"
                            FontWeight="SemiBold">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="3" />
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

    </Grid>
</Window>
