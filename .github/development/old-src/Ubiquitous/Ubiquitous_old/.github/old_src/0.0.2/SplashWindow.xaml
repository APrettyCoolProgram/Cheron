<Window
    x:Class="Ubiquitus.SplashWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Ubiquitus" 
    Height="600" 
    Width="600" 
    WindowStyle="None" 
    AllowsTransparency="True" 
    Background="Transparent"
    WindowStartupLocation="CenterScreen"
    ResizeMode="NoResize"
    Topmost="True"
    MouseDown="Window_MouseDown">
    
    <Grid>
        <Border Background="#E8F0F7" CornerRadius="10" BorderThickness="2" BorderBrush="#CCCCCC">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="40"/>
                </Grid.RowDefinitions>

                <!-- Logo Image -->
                <Image 
                    Grid.Row="0"
                    Source="AppData/Image/Logo/ubiquitus-splash_512x512.png" 
                    Width="400" 
                    Height="400"
                    Margin="20"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"/>

                <!-- Version Number -->
                <TextBlock 
                    Grid.Row="1"
                    x:Name="VersionText"
                    Text="Version 0.0.1"
                    FontSize="20"
                    FontWeight="SemiBold"
                    Foreground="#333333"
                    HorizontalAlignment="Center"
                    Margin="0,10,0,10"/>

                <!-- Loading Indicator -->
                <TextBlock 
                    Grid.Row="2"
                    Text="Loading..."
                    FontSize="14"
                    Foreground="#666666"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Margin="0,0,0,10"/>
            </Grid>
        </Border>
    </Grid>
</Window>
