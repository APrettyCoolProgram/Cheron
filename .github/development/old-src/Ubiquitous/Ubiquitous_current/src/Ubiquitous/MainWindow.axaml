<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Ubiquitous.MainWindow"
        Title="Ubiquitous - Text Adventure Game Player"
        Width="900"
        Height="700"
        MinWidth="600"
        MinHeight="400">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title and Menu Bar -->
        <Border Grid.Row="0" 
                Background="#2d2d30" 
                Padding="10,5"
                CornerRadius="4"
                Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0"
                           Name="GameTitleText"
                           Text="Text Adventure Game Player"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="White"
                           VerticalAlignment="Center"/>
                
                <StackPanel Grid.Column="1" 
                            Orientation="Horizontal" 
                            Spacing="10">
                    <Button Name="NewGameButton"
                            Content="New Game"
                            Click="NewGame_Click"
                            Padding="10,5"/>
                    <Button Name="HelpButton"
                            Content="Help"
                            Click="Help_Click"
                            Padding="10,5"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Game Output Area -->
        <Border Grid.Row="1"
                Background="#1e1e1e"
                BorderBrush="#3f3f46"
                BorderThickness="1"
                CornerRadius="4"
                Margin="0,0,0,10">
            <ScrollViewer Name="OutputScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          Padding="10">
                <TextBlock Name="OutputText"
                           Text="Welcome to Ubiquitous!\n\nClick 'New Game' to start playing the sample adventure game.\n\nType 'help' at any time to see available commands."
                           FontFamily="Consolas,Courier New,monospace"
                           FontSize="14"
                           Foreground="#d4d4d4"
                           TextWrapping="Wrap"/>
            </ScrollViewer>
        </Border>

        <!-- Input Area -->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text=">"
                       FontSize="16"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0"
                       Foreground="#569cd6"/>

            <TextBox Grid.Column="1"
                     Name="InputTextBox"
                     Watermark="Enter command here..."
                     FontSize="14"
                     Padding="5"
                     KeyDown="InputTextBox_KeyDown"/>

            <Button Grid.Column="2"
                    Name="SendButton"
                    Content="Send"
                    Click="Send_Click"
                    Padding="20,5"
                    Margin="10,0,0,0"
                    IsEnabled="False"/>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="3"
                Background="#007acc"
                Padding="10,5"
                CornerRadius="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Name="StatusText"
                           Text="Ready"
                           Foreground="White"
                           VerticalAlignment="Center"/>

                <TextBlock Grid.Column="1"
                           Name="ScoreText"
                           Text="Score: 0"
                           Foreground="White"
                           Margin="0,0,20,0"
                           VerticalAlignment="Center"/>

                <TextBlock Grid.Column="2"
                           Name="MovesText"
                           Text="Moves: 0"
                           Foreground="White"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
