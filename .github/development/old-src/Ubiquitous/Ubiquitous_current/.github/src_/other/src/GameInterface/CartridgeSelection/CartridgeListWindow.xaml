<Window x:Class="Ubiquitous.GameInterface.CartridgeSelection.CartridgeListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Select a Game" Height="600" Width="900"
        Background="#1E1E1E"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" 
                   Grid.Column="0"
                   Grid.ColumnSpan="2"
                   Text="Available Games"
                   FontSize="32"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,10,0,20"
                   Foreground="White"/>

        <!-- Game Type Filter Panel -->
        <Border Grid.Row="1" 
                Grid.Column="0"
                Background="#2D2D30"
                BorderBrush="#3F3F46"
                BorderThickness="1"
                CornerRadius="5"
                Padding="15"
                Margin="0,0,15,0">
            <StackPanel>
                <TextBlock Text="Game Type"
                          FontSize="18"
                          FontWeight="Bold"
                          Foreground="White"
                          Margin="0,0,0,15"/>
                
                <Button x:Name="AllGamesButton"
                        Content="All Games"
                        Padding="10,8"
                        Margin="0,0,0,10"
                        FontSize="14"
                        Background="#007ACC"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="GameTypeButton_Click"
                        Tag="">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="3"/>
                        </Style>
                    </Button.Resources>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1C97EA"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button x:Name="TextGameButton"
                        Content="TextGame"
                        Padding="10,8"
                        Margin="0,0,0,10"
                        FontSize="14"
                        Background="#3F3F46"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="GameTypeButton_Click"
                        Tag="TextGame">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="3"/>
                        </Style>
                    </Button.Resources>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#4F4F56"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Border>

        <!-- Cartridge List -->
        <ScrollViewer Grid.Row="1" 
                     Grid.Column="1"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Disabled">
            <ItemsControl x:Name="CartridgeListControl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#2D2D30"
                                BorderBrush="#3F3F46"
                                BorderThickness="1"
                                CornerRadius="5"
                                Margin="0,5"
                                Padding="15"
                                Cursor="Hand"
                                MouseDown="CartridgeItem_MouseDown"
                                Tag="{Binding FilePath}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#3E3E42"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Title -->
                                <TextBlock Grid.Row="0"
                                          Text="{Binding Title}"
                                          FontSize="20"
                                          FontWeight="Bold"
                                          Foreground="White"
                                          Margin="0,0,0,5"/>

                                <!-- Author and Version -->
                                <TextBlock Grid.Row="1"
                                          FontSize="12"
                                          Foreground="#CCCCCC"
                                          Margin="0,0,0,5">
                                    <Run Text="by "/>
                                    <Run Text="{Binding Author}"/>
                                    <Run Text=" - Version "/>
                                    <Run Text="{Binding Version}"/>
                                </TextBlock>

                                <!-- Game Properties (Genre, Difficulty) -->
                                <TextBlock Grid.Row="2"
                                          FontSize="12"
                                          Foreground="#AAAAAA"
                                          Margin="0,0,0,8">
                                    <Run Text="{Binding Genre}" FontWeight="SemiBold"/>
                                    <Run Text=" | "/>
                                    <Run Text="{Binding Difficulty}" FontWeight="SemiBold"/>
                                </TextBlock>

                                <!-- Description -->
                                <TextBlock Grid.Row="3"
                                          Text="{Binding Description}"
                                          FontSize="14"
                                          Foreground="#AAAAAA"
                                          TextWrapping="Wrap"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Back Button -->
        <Button Grid.Row="2"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                x:Name="BackButton"
                Content="Back"
                Padding="30,12"
                Margin="0,20,0,0"
                FontSize="16"
                FontWeight="SemiBold"
                Background="#2D2D30"
                Foreground="White"
                BorderThickness="1"
                BorderBrush="#3F3F46"
                Cursor="Hand"
                HorizontalAlignment="Center"
                Click="BackButton_Click">
            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="5"/>
                </Style>
            </Button.Resources>
            <Button.Style>
                <Style TargetType="Button">
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#3E3E42"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>
    </Grid>
</Window>
