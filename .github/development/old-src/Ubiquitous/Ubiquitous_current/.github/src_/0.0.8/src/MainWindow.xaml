<Window x:Class="Ubiquitous.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Ubiquitous"
        mc:Ignorable="d"
        Title="Ubiquitous Game Engine" Height="600" Width="800"
        Background="#1E1E1E"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Logo -->
        <Image Grid.Row="0" 
               Source="pack://application:,,,/AppData/Image/Logo/ubiquitus-dark_128x128.png"
               Stretch="Uniform"
               Width="128"
               Height="128"
               HorizontalAlignment="Center"
               Margin="0,20,0,40">
            <Image.Effect>
                <DropShadowEffect Color="White" 
                                Direction="270" 
                                ShadowDepth="0" 
                                BlurRadius="30" 
                                Opacity="0.4"/>
            </Image.Effect>
        </Image>

        <!-- Main Buttons -->
        <Grid Grid.Row="1" 
              VerticalAlignment="Center"
              HorizontalAlignment="Center"
              Width="500">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <Button Grid.Column="0"
                    x:Name="PlayButton"
                    Content="PLAY"
                    Padding="30,20"
                    FontSize="24"
                    FontWeight="Bold"
                    Background="#2D2D30"
                    Foreground="White"
                    BorderThickness="2"
                    BorderBrush="#3F3F46"
                    Cursor="Hand"
                    Click="PlayButton_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="8"/>
                    </Style>
                </Button.Resources>
                <Button.Style>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3E3E42"/>
                                <Setter Property="BorderBrush" Value="#FFFFFF"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button Grid.Column="2"
                    x:Name="CreateButton"
                    Content="CREATE"
                    Padding="30,20"
                    FontSize="24"
                    FontWeight="Bold"
                    Background="#2D2D30"
                    Foreground="White"
                    BorderThickness="2"
                    BorderBrush="#3F3F46"
                    Cursor="Hand"
                    Click="CreateButton_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="8"/>
                    </Style>
                </Button.Resources>
                <Button.Style>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3E3E42"/>
                                <Setter Property="BorderBrush" Value="#FFFFFF"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>

        <!-- Settings Button -->
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,20,0,0">
            <Button x:Name="SettingsButton"
                    Padding="20,12"
                    Margin="10,0"
                    FontSize="18"
                    FontWeight="SemiBold"
                    Background="#2D2D30"
                    Foreground="White"
                    BorderThickness="1"
                    BorderBrush="#3F3F46"
                    Cursor="Hand"
                    Click="SettingsButton_Click"
                    ToolTip="Settings">
                <Button.Content>
                    <TextBlock Text="?" FontSize="24"/>
                </Button.Content>
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
                <Button.Style>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3E3E42"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
</Window>
