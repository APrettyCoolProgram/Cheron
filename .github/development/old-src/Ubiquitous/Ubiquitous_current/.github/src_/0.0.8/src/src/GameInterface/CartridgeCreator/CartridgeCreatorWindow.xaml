<Window x:Class="Ubiquitous.GameInterface.CartridgeCreator.CartridgeCreatorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Create New TextGame" Height="800" Width="1200"
        Background="#1E1E1E"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" 
                   Text="Create New TextGame Cartridge"
                   FontSize="32"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,10,0,20"
                   Foreground="White"/>

        <!-- Tab Control -->
        <TabControl Grid.Row="1"
                    x:Name="MainTabControl"
                    Background="#2D2D30"
                    BorderBrush="#3F3F46"
                    BorderThickness="1">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Background" Value="#2D2D30"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Padding" Value="20,10"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border Name="Border" 
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="#3F3F46"
                                        BorderThickness="1,1,1,0"
                                        CornerRadius="5,5,0,0"
                                        Margin="2,0">
                                    <ContentPresenter x:Name="ContentSite"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Center"
                                                    ContentSource="Header"
                                                    Margin="{TemplateBinding Padding}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#007ACC"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#3E3E42"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <!-- Metadata Tab -->
            <TabItem Header="Game Info">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#1E1E1E">
                    <Border Background="#2D2D30"
                            BorderBrush="#3F3F46"
                            BorderThickness="1"
                            CornerRadius="5"
                            Padding="20"
                            Margin="20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0"
                                      Text="Title:"
                                      FontSize="14"
                                      Foreground="White"
                                      VerticalAlignment="Center"
                                      Margin="0,5"/>
                            <TextBox Grid.Row="0" Grid.Column="1"
                                    x:Name="TitleTextBox"
                                    Background="#3F3F46"
                                    Foreground="White"
                                    BorderBrush="#555555"
                                    Padding="8"
                                    FontSize="14"
                                    Margin="10,5"/>

                            <TextBlock Grid.Row="1" Grid.Column="0"
                                      Text="Author:"
                                      FontSize="14"
                                      Foreground="White"
                                      VerticalAlignment="Center"
                                      Margin="0,5"/>
                            <TextBox Grid.Row="1" Grid.Column="1"
                                    x:Name="AuthorTextBox"
                                    Background="#3F3F46"
                                    Foreground="White"
                                    BorderBrush="#555555"
                                    Padding="8"
                                    FontSize="14"
                                    Margin="10,5"/>

                            <TextBlock Grid.Row="2" Grid.Column="0"
                                      Text="Version:"
                                      FontSize="14"
                                      Foreground="White"
                                      VerticalAlignment="Center"
                                      Margin="0,5"/>
                            <TextBox Grid.Row="2" Grid.Column="1"
                                    x:Name="VersionTextBox"
                                    Text="1.0.0"
                                    Background="#3F3F46"
                                    Foreground="White"
                                    BorderBrush="#555555"
                                    Padding="8"
                                    FontSize="14"
                                    Margin="10,5"/>

                            <TextBlock Grid.Row="3" Grid.Column="0"
                                      Text="UI Type:"
                                      FontSize="14"
                                      Foreground="White"
                                      VerticalAlignment="Center"
                                      Margin="0,5"/>
                            <ComboBox Grid.Row="3" Grid.Column="1"
                                     x:Name="UITypeComboBox"
                                     Background="#3F3F46"
                                     Foreground="White"
                                     BorderBrush="#555555"
                                     Padding="8"
                                     FontSize="14"
                                     Margin="10,5">
                                <ComboBoxItem Content="Basic" IsSelected="True"/>
                                <ComboBoxItem Content="Fancy"/>
                            </ComboBox>

                            <TextBlock Grid.Row="4" Grid.Column="0"
                                      Text="Difficulty:"
                                      FontSize="14"
                                      Foreground="White"
                                      VerticalAlignment="Center"
                                      Margin="0,5"/>
                            <ComboBox Grid.Row="4" Grid.Column="1"
                                     x:Name="DifficultyComboBox"
                                     Background="#3F3F46"
                                     Foreground="White"
                                     BorderBrush="#555555"
                                     Padding="8"
                                     FontSize="14"
                                     Margin="10,5">
                                <ComboBoxItem Content="Easy" IsSelected="True"/>
                                <ComboBoxItem Content="Intermediate"/>
                                <ComboBoxItem Content="Hard"/>
                                <ComboBoxItem Content="Expert"/>
                            </ComboBox>

                            <TextBlock Grid.Row="5" Grid.Column="0"
                                      Text="Genre:"
                                      FontSize="14"
                                      Foreground="White"
                                      VerticalAlignment="Center"
                                      Margin="0,5"/>
                            <ComboBox Grid.Row="5" Grid.Column="1"
                                     x:Name="GenreComboBox"
                                     Background="#3F3F46"
                                     Foreground="White"
                                     BorderBrush="#555555"
                                     Padding="8"
                                     FontSize="14"
                                     Margin="10,5">
                                <ComboBoxItem Content="Fantasy" IsSelected="True"/>
                                <ComboBoxItem Content="Science Fiction"/>
                                <ComboBoxItem Content="Romance"/>
                            </ComboBox>

                            <TextBlock Grid.Row="6" Grid.Column="0"
                                      Text="Description:"
                                      FontSize="14"
                                      Foreground="White"
                                      VerticalAlignment="Top"
                                      Margin="0,5"/>
                            <TextBox Grid.Row="6" Grid.Column="1"
                                    x:Name="DescriptionTextBox"
                                    Background="#3F3F46"
                                    Foreground="White"
                                    BorderBrush="#555555"
                                    Padding="8"
                                    FontSize="14"
                                    TextWrapping="Wrap"
                                    AcceptsReturn="True"
                                    Height="100"
                                    VerticalScrollBarVisibility="Auto"
                                    Margin="10,5"/>

                            <TextBlock Grid.Row="7" Grid.Column="0"
                                      Text="Starting Room ID:"
                                      FontSize="14"
                                      Foreground="White"
                                      VerticalAlignment="Center"
                                      Margin="0,5"/>
                            <ComboBox Grid.Row="7" Grid.Column="1"
                                     x:Name="StartingRoomIdComboBox"
                                     Background="#3F3F46"
                                     Foreground="White"
                                     BorderBrush="#555555"
                                     Padding="8"
                                     FontSize="14"
                                     IsEditable="True"
                                     Margin="10,5"/>
                        </Grid>
                    </Border>
                </ScrollViewer>
            </TabItem>

            <!-- Rooms Tab -->
            <TabItem Header="Rooms">
                <Grid Background="#1E1E1E">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="250"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Room List -->
                    <Border Grid.Column="0" 
                            Background="#2D2D30"
                            BorderBrush="#3F3F46"
                            BorderThickness="1"
                            Margin="10">
                        <DockPanel>
                            <Button DockPanel.Dock="Top"
                                    Content="+ Add Room"
                                    Background="#007ACC"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Padding="10"
                                    Margin="10"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Cursor="Hand"
                                    Click="AddRoomButton_Click"/>
                            <ListBox x:Name="RoomListBox"
                                     Background="#1E1E1E"
                                     Foreground="White"
                                     BorderThickness="0"
                                     SelectionChanged="RoomListBox_SelectionChanged"
                                     Margin="10,0,10,10">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" 
                                                  FontSize="14"
                                                  Padding="5"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>

                    <!-- Room Editor -->
                    <ScrollViewer Grid.Column="1" 
                                 VerticalScrollBarVisibility="Auto"
                                 Margin="10">
                        <Border Background="#2D2D30"
                                BorderBrush="#3F3F46"
                                BorderThickness="1"
                                CornerRadius="5"
                                Padding="20">
                            <StackPanel x:Name="RoomEditorPanel">
                                <TextBlock Text="Select or add a room to edit"
                                          Foreground="#AAAAAA"
                                          FontSize="16"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="0,50"/>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- Items Tab -->
            <TabItem Header="Items">
                <Grid Background="#1E1E1E">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="250"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Item List -->
                    <Border Grid.Column="0" 
                            Background="#2D2D30"
                            BorderBrush="#3F3F46"
                            BorderThickness="1"
                            Margin="10">
                        <DockPanel>
                            <Button DockPanel.Dock="Top"
                                    Content="+ Add Item"
                                    Background="#007ACC"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Padding="10"
                                    Margin="10"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Cursor="Hand"
                                    Click="AddItemButton_Click"/>
                            <ListBox x:Name="ItemListBox"
                                     Background="#1E1E1E"
                                     Foreground="White"
                                     BorderThickness="0"
                                     SelectionChanged="ItemListBox_SelectionChanged"
                                     Margin="10,0,10,10">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" 
                                                  FontSize="14"
                                                  Padding="5"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>

                    <!-- Item Editor -->
                    <ScrollViewer Grid.Column="1" 
                                 VerticalScrollBarVisibility="Auto"
                                 Margin="10">
                        <Border Background="#2D2D30"
                                BorderBrush="#3F3F46"
                                BorderThickness="1"
                                CornerRadius="5"
                                Padding="20">
                            <StackPanel x:Name="ItemEditorPanel">
                                <TextBlock Text="Select or add an item to edit"
                                          Foreground="#AAAAAA"
                                          FontSize="16"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="0,50"/>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="2" 
                   Orientation="Horizontal"
                   HorizontalAlignment="Center"
                   Margin="0,20,0,0">
            <Button x:Name="CreateButton"
                    Content="Create Cartridge"
                    Padding="30,12"
                    Margin="10,0"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Background="#007ACC"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="CreateButton_Click"/>

            <Button x:Name="CancelButton"
                    Content="Cancel"
                    Padding="30,12"
                    Margin="10,0"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Background="#2D2D30"
                    Foreground="White"
                    BorderThickness="1"
                    BorderBrush="#3F3F46"
                    Cursor="Hand"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
